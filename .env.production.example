# 운영(EKS) 환경 변수 "키 명세" 템플릿 — 실제 값은 절대 커밋하지 않는다.
# 이 파일은 "어떤 키가 필요한지"를 문서화할 뿐, 값은 비워 두거나 예시만 둔다.
#
# 주입 방식
#   - [SECRET]          → Kubernetes Secret 으로 주입 (DB/Redis 접속 문자열 등)
#   - [CONFIG]          → ConfigMap 으로 주입 (비밀이 아닌 런타임 설정)
#   - 중기 권장: AWS Secrets Manager + External Secrets Operator(ESO)로 Secret 외부화
#     (로컬 개발엔 과함 — EKS 이관 시점에 도입. docs/migrations.md / technical-handover 참고)

# ── [SECRET] DB — RDS/Aurora PostgreSQL ──
# 운영은 전송 암호화 강제 권장(sslmode=require).
DATABASE_URL="postgresql://USER:PASSWORD@your-rds-endpoint:5432/mono?schema=public&sslmode=require"
# (선택) 마이그레이션 Job 전용 최소권한 계정을 분리할 경우:
# MIGRATE_DATABASE_URL="postgresql://migrator:PASSWORD@your-rds-endpoint:5432/mono?schema=public&sslmode=require"

# ── [SECRET] Redis — ElastiCache ──
# 전송 암호화 사용 시 rediss://
REDIS_URL="rediss://your-elasticache-endpoint:6379"

# ── [CONFIG] 비밀 아님 ──
PORT="8000"
NODE_ENV="production"
# 앱 pod 에서는 마이그레이션을 적용하지 않는다(별도 마이그레이션 Job 이 담당).
RUN_MIGRATIONS="0"
