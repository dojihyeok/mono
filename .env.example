# 이 파일을 복사해 .env 를 만드세요:  cp .env.example .env
# .env 는 커밋하지 않습니다(.gitignore 참고). 운영 키 명세는 .env.production.example.

# ── [SECRET] Postgres 자격증명 (compose db 서비스 + DATABASE_URL 의 단일 출처) ──
POSTGRES_USER=mono
POSTGRES_PASSWORD=mono_dev_pw
POSTGRES_DB=mono

# ── [SECRET] Prisma 연결 문자열 — 호스트 도구(prisma CLI)·web 용 ──
# 로컬(호스트→Docker Compose db, 호스트=localhost) 기본값:
DATABASE_URL="postgresql://mono:mono_dev_pw@localhost:5432/mono?schema=public"
# 참고: api 컨테이너용 URL 은 compose 가 POSTGRES_* 로 자동 구성한다(호스트=db). 따로 둘 필요 없음.

# ── Redis (세션 / 인증코드(OTP) / 레이트리밋 / 캐시) ──
# 로컬(Docker Compose) 기본값:
REDIS_URL="redis://localhost:6379"
