# 웹(Next.js) 환경변수 — 실제 값은 .env(.gitignore)나 시크릿으로 주입
# API_URL: BFF 라우트가 백엔드 API 로 포워딩할 주소(필수)
#   - 로컬(호스트):     http://localhost:8000
#   - 컨테이너/compose: http://api:8000
#   - 쿠버네티스:        http://api.<namespace>:8000
API_URL=http://localhost:8000

# DATABASE_URL: web 이 prisma 로 DB 에 직접 접근할 때만 필요(BFF 프록시만 쓰면 불필요)
#   - 컨테이너: postgresql://mono:mono_dev_pw@db:5432/mono?schema=public
DATABASE_URL=postgresql://mono:mono_dev_pw@localhost:5432/mono?schema=public
