// Prisma 스키마 — MONO
// 사용자 앱 MVP의 핵심 도메인(사용자·경력·자격·관심신청·이벤트로그)을 정의합니다.
// 상세 기준: docs/user-app-guidelines.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String   @id @default(cuid())
  phone       String?  @unique
  email       String?  @unique
  name        String?
  jobType     String? // 직군
  careerYears Int? // 경력 연차
  region      String? // 희망 지역
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  careerCards  CareerCard[]
  certificates Certificate[]
  educations   Education[]
  interests    InterestRegistration[]
  events       AnalyticsEvent[]
}

model CareerCard {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  siteName  String // 현장명
  field     String? // 작업 분야
  startDate DateTime?
  endDate   DateTime?
  role      String? // 역할
  equipment String? // 사용 장비
  coworkers String? // 함께 일한 사람
  memo      String?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Certificate {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  issuer    String?
  issuedAt  DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Education {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  institute   String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

// 규제·API 연동 필요 기능 → "관심 신청/관심 등록" (docs/user-app-guidelines.md 5장)
enum InterestFeature {
  CAREER_VERIFICATION // 경력 인증
  FINANCE_BENEFIT // 금융 혜택
  EQUIPMENT_RENTAL // 공구·장비 대여
  FOREIGN_WORKER // 외국인 체류·고용 관리
  SAFE_PAYMENT // 안심 정산
  COMPANY_VIEW // 기업 열람권
}

model InterestRegistration {
  id        String          @id @default(cuid())
  userId    String?
  user      User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  feature   InterestFeature
  createdAt DateTime        @default(now())

  @@index([userId])
}

// 마케팅 분석용 이벤트 로그 (docs/user-app-guidelines.md 6장)
model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name      String // 예: signup_completed, career_added
  props     Json?
  createdAt DateTime @default(now())

  @@index([name])
  @@index([userId])
}

// 홈 화면 맞춤형 AI 인사이트 / 공지사항
model AiInsight {
  id         String   @id @default(cuid())
  type       String   // URGENT_JOB, REGION_INFO, WEATHER_INFO 등
  title      String
  content    String
  linkText   String?
  linkTarget String?  // 예: jobs-nearby, training-programs 등
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
